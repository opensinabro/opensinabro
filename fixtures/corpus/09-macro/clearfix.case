근거: 도움말예제 | 원문: 1줄 | 의미론: 14줄 | 렌더링: 1줄 | float 초기화
[clearfix]
Document {
    blocks: [
        Paragraph(
            [
                Macro(
                    Macro {
                        name: "clearfix",
                        argument: None,
                    },
                ),
            ],
        ),
    ],
}
<div class="wiki-paragraph"><div class="wiki-clearfix"></div></div>
