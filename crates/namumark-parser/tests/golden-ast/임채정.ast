  Row:
    Cell span=1x1 align=Some(Center) attrs=[Table/align=center Table/width=100% Table/bordercolor=#004ea2 Table/bgcolor=#f5f5f5,#191919 Cell/width=10% Row/bgcolor=#004ea2]:
      Paragraph: Colored(#ffffff | "연도")
