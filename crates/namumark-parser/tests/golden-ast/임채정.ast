    Cell span=1x1 align=Some(Center):
      Paragraph: "낙선 (2위)"
    Cell span=1x1 align=Some(Right):
  Row:
    Cell span=1x1 align=Some(Center):
      Paragraph: "1992"
    Cell span=1x1 align=Some(Center):
      Paragraph: Link("제14대 국회의원 선거")
